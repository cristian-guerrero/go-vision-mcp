{
  "name": "go-vision-mcp",
  "version": "0.5.0",
  "description": "MCP server for vision analysis using local GGUF models via llama.cpp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cristian-guerrero/go-vision-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/cristian-guerrero/go-vision-mcp/issues"
  },
  "homepage": "https://github.com/cristian-guerrero/go-vision-mcp#readme",
  "keywords": [
    "mcp",
    "vision",
    "llama",
    "gguf",
    "model-context-protocol",
    "llm",
    "image-analysis"
  ],
  "engines": {

    "go-vision-mcp-win32-arm64": "0.5.0",
    "go-vision-mcp-darwin-x64": "0.5.0",
    "go-vision-mcp-darwin-arm64": "0.5.0",
    "go-vision-mcp-linux-x64": "0.5.0",
    "go-vision-mcp-linux-arm64": "0.5.0"
  }
}
